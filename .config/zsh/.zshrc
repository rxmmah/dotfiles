##
## rxyhn's Z-Shell configuration
## https://github.com/rxyhn

while read file
do 
  source "$ZDOTDIR/$file.zsh"
done <<-EOF
theme
env
aliases
utility
options
plugins
keybinds
prompt
EOF
bindkey -v
# Custom key binding to open Vim with a temporary file

if [[ $TERM == "foot" ]]; then
    tmux 
fi

# vim:ft=zsh:nowrap
